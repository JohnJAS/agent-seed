{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node --experimental-vm-modules \".claude/skills/ai-code-tracker/scripts/claude-code-hook.js\" pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node --experimental-vm-modules \".claude/skills/ai-code-tracker/scripts/claude-code-hook.js\" post"
          }
        ]
      }
    ]
  }
}
