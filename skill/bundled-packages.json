{
  "activation_policy": {
    "on_agent_seed_start": "must_check",
    "default_install_action": "must_offer_before_onboarding",
    "requires_user_approval": true,
    "skip_reason_required": true,
    "recurring_install_prompt": {
      "applies_to": [
        "git-code-tracker"
      ],
      "missing_action": "must_ask_every_activation_before_onboarding",
      "declined_action": "record_reason_and_continue",
      "previous_decline_suppresses_prompt": false
    }
  },
  "bundled_packages": [
    {
      "name": "git-code-tracker",
      "version": "v1.0.4",
      "kind": "multi-platform-release-asset",
      "source": {
        "type": "github-release-asset",
        "repo": "https://github.com/yooocen/git-code-tracker",
        "ref": "refs/tags/v1.0.4",
        "commit": "8cb0855155c8ad7483232e9d5679ee19d8714df8",
        "asset": "ai-commit-statistic-skill-v1.0.4.zip"
      },
      "asset_path": "packages/git-code-tracker/ai-commit-statistic-skill-v1.0.4.zip",
      "default_install": {
        "mode": "project-local",
        "offer_by_default": true,
        "requires_user_approval": true,
        "auto_detect_platform": true,
        "command": "node scripts/install-git-code-tracker.mjs <target-project> [--platform <detected-platform>]",
        "writes": [
          ".opencode/skills/ai-code-tracker",
          ".claude/skills/ai-code-tracker",
          ".cac/skills/ai-code-tracker",
          ".opencode/plugins/ai-code-tracker.js",
          ".opencode/commands",
          ".claude/commands",
          ".claude/settings.json",
          ".cac/commands",
          ".cac/settings.json",
          ".ai-tracking",
          ".ai-tracking/config.json",
          ".ai-tracking/upload-outbox.json",
          ".git/hooks",
          ".gitignore",
          "AGENTS.md"
        ]
      },
      "upload": {
        "config_path": ".ai-tracking/config.json",
        "default_url": "http://7.213.196.158:8088/v1/records",
        "trigger": "git pre-push hook",
        "outbox_path": ".ai-tracking/upload-outbox.json",
        "preserve_existing_url": true
      },
      "platform_skills": [
        {
          "platform": "opencode",
          "name": "ai-code-tracker",
          "source_path": ".opencode/skills/ai-code-tracker",
          "target_path": ".opencode/skills/ai-code-tracker",
          "verification": "node .opencode/skills/ai-code-tracker/scripts/install.js --check"
        },
        {
          "platform": "claude",
          "name": "ai-code-tracker",
          "source_path": ".claude/skills/ai-code-tracker",
          "target_path": ".claude/skills/ai-code-tracker",
          "verification": "node .claude/skills/ai-code-tracker/scripts/install.js --check"
        },
        {
          "platform": "codeagent-cli",
          "name": "ai-code-tracker",
          "source_path": ".cac/skills/ai-code-tracker",
          "target_path": ".cac/skills/ai-code-tracker",
          "verification": "node .cac/skills/ai-code-tracker/scripts/install.js --check"
        }
      ],
      "safety": {
        "personal_directory_install_requires_explicit_request": true
      }
    }
  ]
}
